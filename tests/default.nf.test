nextflow_pipeline {

    name "Test Workflow main.nf"
    script "../main.nf"
    tag "pipeline"
    profile "test"

    test("-profile test") {

        when {
            params {
                outdir = "$outputDir"
                input = "$baseDir" + "/samplesheets/test.csv"
                runname = "test"
            }
        }

        then {
            assertAll(
                { assert workflow.success},
                { assert snapshot(
                        path("${params.outdir}/report_no_ntc/test_spntypeid_report.csv").md5,
                        path("${params.outdir}/assembly_stats_summary/assembly_stats_results_summary.tsv").md5,
                        path("${params.outdir}/bbduk_summary/bbduk_results.tsv").md5,
                        path("${params.outdir}/quality_stats/quality_stats.tsv").md5,
                        path("${params.outdir}/coverage_stats/coverage_stats.tsv").md5,
                        path("${params.outdir}/quast_summary/quast_results.tsv").md5,
                        path("${params.outdir}/pipeline_info/software_versions.yml").md5,
                        path("${params.outdir}/percent_strep_summary/percent_strep_results.tsv").md5,
                        path("${params.outdir}/seroba_summary/seroba_results.tsv").md5
                    )
                }
            )
        }

    }

}
