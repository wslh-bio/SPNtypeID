nextflow_process {

    name "Test Process BBDUK"
    script "modules/local/bbduk/bbduk.nf"
    process "BBDUK"

    test("Should run without failures") {

        when {
            process {
                """
                // define inputs of the process here. Example:
                input[0] = [[ id:'test', single_end:false ], [file(params.modules_testdata_base_path + 'SPN_Sample_01_R1.fastq.gz'),file(params.modules_testdata_base_path + 'SPN_Sample_01_R2.fastq.gz']]
                """
            }
        }

        then {
            assert process.success
            assert snapshot(process.out).match()
        }

    }

}
