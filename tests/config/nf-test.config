def nftProfile = System.getenv("NFT_PROFILE") ?: "test"
def nftBucketDir = System.getenv("NFT_BUCKET_DIR")
if (!nftBucketDir && nftProfile.contains("awsdev")) {
    nftBucketDir = "s3://dev-wslh-sequencing-analyses/work/"
}
if (!nftBucketDir && nftProfile.contains("awsprod")) {
    nftBucketDir = "s3://prod-wslh-sequencing-analyses/work/"
}

config {
    // location for all nf-tests
    testsDir = "."

    // nf-test directory including temporary files for each test
    workDir System.getenv("NFT_WORKDIR") ?: ".nf-test"

    // location of an optional nextflow.config file specific for executing tests
    configFile = "tests/config/nextflow.config"

    // Allow overriding profiles at runtime, e.g. NFT_PROFILE="test,awsdev"
    profile nftProfile

    // awsbatch requires bucket-dir/work-dir on CLI; set bucket-dir automatically for AWS profiles.
    if (nftBucketDir) {
        options "-bucket-dir ${nftBucketDir}"
    }

    // List of filenames or patterns that should trigger a full test run if changed
    triggers 'conf/test.config', 'conf/test_full.config', 'nextflow.config', 'nf-test.config', 'tests/config/nextflow.config', 'tests/config/nf-test.config'

    // adding extra utilities to nf-test
    plugins {
        load "nft-utils@0.0.9"
    }
}
