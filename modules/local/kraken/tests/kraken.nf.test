nextflow_process {

    name "Test Process KRAKEN"
    script "modules/local/kraken/kraken.nf"
    process "KRAKEN"

    test("Checking that output channels have appropriate amount of values") {

        when {
            params {
                // define parameters here. Example:
                // outdir = "tests/results"
            }
            process {
                """
                input[0] = [ 
                [id:'test', single_end:false ],
                [ file("${baseDir}" + '/test-dataset/SPN_Sample_01_R1.fastq.gz'),
                file("${baseDir}" + '/test-dataset/SPN_Sample_01_R2.fastq.gz') ]
                ]
                """
            }
        }

        then {
            assertAll{
                { assert process.success }
                { assert process.out.kraken_results.size() == 1}
                { assert process.out.versions.size() == 1}
            }

        }

    }

    test("Checking that output channels have appropriate amount of values") {

        when {
            params {
                // define parameters here. Example:
                // outdir = "tests/results"
            }
            process {
                """
                input[0] = [ 
                [id:'test', single_end:false ],
                [ file("${baseDir}" + '/test-dataset/SPN_Sample_01_R1.fastq.gz'),
                file("${baseDir}" + '/test-dataset/SPN_Sample_01_R2.fastq.gz') ]
                ]
                """
            }
        }

        then {
            assertAll{
                { assert process.success }
                { assert process.out.kraken_results.size() == 1}
                { assert process.out.versions.size() == 1}
            }

        }

    }

}
