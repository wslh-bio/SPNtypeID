nextflow_process {

    name "Test Process BBDUK"
    script "../bbduk.nf"
    process "BBDUK"

    test("Checking that mandatory output channels have appropriate amount of values") {

        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = [ 
                [id:'test', single_end:false ],
                [ file("${baseDir}" + '/test-dataset/SPN_Sample_01_R1.fastq.gz'),
                file("${baseDir}" + '/test-dataset/SPN_Sample_01_R2.fastq.gz') ]
                ]
                input[1] = file("${baseDir}" + "/modules/local/bbduk/tests/adapters.fa")
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert process.out.reads.size() == 1 },
                { assert process.out.log.size() == 1 },
                { assert process.out.bbduk_trim.size() == 1 },
                { assert process.out.bbduk_adapters.size() == 1 },
                { assert process.out.versions.size() == 1 }
            )
        }

    }

    test('Checking that optional output channels have appropriate amount of values') {

        when {
            params {
                outdir = "$outputDir"
            }

            process {
                """
                input[0] = [ 
                [id:'test', single_end:false ],
                [ file("${baseDir}" + '/test-dataset/SPN_Sample_01_R1.fastq.gz'),
                file("${baseDir}" + '/test-dataset/SPN_Sample_01_R2.fastq.gz') ]
                ]
                input[1] = file("${baseDir}" + "/modules/local/bbduk/tests/adapters.fa")
                """
            }
        }
        then {
            assertAll (

                { assert process.out.repaired_reads.size() == 1 },
                { assert process.out.singletons.size() == 1 },
                { assert process.out.repaired_log.size() == 1 }

            )
        }
    }

    test('Checking mandatory file contents to ensure proper processing.') {

        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = [ 
                [id:'test', single_end:false ],
                [ file("${baseDir}" + '/test-dataset/SPN_Sample_01_R1.fastq.gz'),
                file("${baseDir}" + '/test-dataset/SPN_Sample_01_R2.fastq.gz') ]
                ]
                input[1] = file("${baseDir}" + "/modules/local/bbduk/tests/adapters.fa")
                """
            }
        }
        then {
            assertAll(
                { assert file(process.out.reads[0][1][0]).name ==~ "test_trimmed_1.fastq.gz" },
                { assert file(process.out.reads[0][1][1]).name ==~ "test_trimmed_2.fastq.gz" },
                { assert path(process.out.log[0][1]).getText().contains("Input is being processed as paired") },
                { assert path(process.out.bbduk_adapters.get(0)).getText().contains("#File	test_repaired_1.fastq.gz	test_repaired_2.fastq.gz") },
                { assert snapshot(path(process.out.versions[0]).md5).match() }
            )
        }
    }

}
