nextflow_process {

    name "Test Process ASSEMBLY_STATS_SUMMARY"
    script "modules/local/assembly_stats_summary/assembly_stats_summary.nf"
    process "ASSEMBLY_STATS_SUMMARY"

    test("Checking that output channel has appropriate amount of values") {

        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = file("${baseDir}" + "/modules/local/assembly_stats_summary/tests/data/*")
                """
            }
        }

        then {
            assertAll (
                { assert process.success },
                { assert process.out.assembly_stats_tsv.size() == 1 }
            )
        }

    }

    test("Checking that output channel has appropriate contents") {

        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = file("${baseDir}" + "/modules/local/assembly_stats_summary/tests/data/*")
                """
            }
        }

        then {
            assertAll(
                { assert snapshot(
                    path(process.out.assembly_stats_tsv[0]).md5
                    ).match()
                }
            )
        }

    }

}
