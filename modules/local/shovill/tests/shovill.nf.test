nextflow_process {

    name "Test Process SHOVILL"
    script "modules/local/shovill/shovill.nf"
    process "SHOVILL"

    test("Checking that mandatory output channels have appropriate amount of values") {

        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = [ 
                [id:'test', single_end:false ],
                [ file("${baseDir}" + '/test-dataset/SPN_Sample_01_R1.fastq.gz'),
                file("${baseDir}" + '/test-dataset/SPN_Sample_01_R2.fastq.gz') ]
                ]
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert process.out.contigs.size() == 1 },
                { assert process.out.sam_files.size() == 1 },
                { assert process.out.corrections.size() == 1 },
                { assert process.out.log.size() == 1 },
                { assert process.out.raw_contigs.size() == 1 },
                { assert process.out.versions.size() == 1 }
            )

        }

    }

    test("Checking that optional output channels have appropriate amount of values") {

        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = [ 
                [id:'test', single_end:false ],
                [ file("${baseDir}" + '/test-dataset/SPN_Sample_01_R1.fastq.gz'),
                file("${baseDir}" + '/test-dataset/SPN_Sample_01_R2.fastq.gz') ]
                ]
                """
            }
        }

        then {
            assert process.out.gfa.size() == 1
        }

    }

    test("Checking that output channels have appropriate contents") {

        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = [ 
                [id:'test', single_end:false ],
                [ file("${baseDir}" + '/test-dataset/SPN_Sample_01_R1.fastq.gz'),
                file("${baseDir}" + '/test-dataset/SPN_Sample_01_R2.fastq.gz') ]
                ]
                """
            }
        }

        then {
            def output_dir_shovill = "$outputDir/shovill/test_shovill_output"
            // assertAll(
            //     { assert path(process.out.versions[0]).md5 == "aa657c335ef793da97b3d627140e7fb2" },
            //     { assert path("$output_dir_shovill/contigs.gfa").md5 == "e18c12c87b06456f7ec65ed70d9e8139" },
            //     { assert path("$output_dir_shovill/shovill.corrections").md5 == "f039fd39b7bed592d6963037578500dc" },
            //     { assert path("$output_dir_shovill/spades.fasta").md5 == "ccbdc9769e97cc91b4fb2c728c402725" } 
            // )
            assertAll(
                { assert snapshot(path(process.out.versions[0]).md5,path("$output_dir_shovill/contigs.gfa").md5,path("$output_dir_shovill/contigs.gfa").md5,path("$output_dir_shovill/spades.fasta").md5).match() }
            )
        }

    }

}
