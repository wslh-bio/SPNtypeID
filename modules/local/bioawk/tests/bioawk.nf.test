nextflow_process {

    name "Test Process BIOAWK"
    script "modules/local/bioawk/bioawk.nf"
    process "BIOAWK"

    test("Checking that output channels have appropriate amount of values") {

        when {
            process {
                """
                input[0] = [ 
                [id:'test', single_end:false ],
                [ file("${baseDir}" + '/test-dataset/SPN_Sample_01_R1.fastq.gz'),
                file("${baseDir}" + '/test-dataset/SPN_Sample_01_R2.fastq.gz') ]
                ]
                """
            }
        }

        then { 
            assertAll {
                { assert process.success }
                { assert process.out.qual_results.size()==1 }
                { assert process.out.versions.size()==1 }

            }
        }
    }


    test("Checking snapshot ") {

        when {
            process {
                """
                input[0] = [ 
                [id:'test', single_end:false ],
                [ file("${baseDir}" + '/test-dataset/SPN_Sample_01_R1.fastq.gz'),
                file("${baseDir}" + '/test-dataset/SPN_Sample_01_R2.fastq.gz') ]
                ]
                """
            }
        }

        then {
            { assert snapshot(process.out).match() }
        }

    }

}
